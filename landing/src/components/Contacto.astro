---
const contactInfo = [
  { icon: 'location', text: 'Marina Alfaro 1110, San Miguel de Tucumán', href: 'https://maps.app.goo.gl/WQvpQjkDQRzsAp336' },
  { icon: 'location', text: 'Salta 805 (Centro), San Salvador de Jujuy', href: 'https://maps.app.goo.gl/Uwu2As9dRLGiv39S6' },
  { icon: 'phone', text: '0810 555 6626 · 381 401 1891' },
  { icon: 'email', text: 'contacto@noanet.com.ar' },
  { icon: 'clock', text: 'Horario de atención: 8:00 a 17:00' }
];

const socialLinks = [
  { name: 'Instagram', url: 'https://www.instagram.com/noanet_sa/', icon: 'instagram' },
  { name: 'Facebook', url: 'https://www.facebook.com/profile.php?id=100078094231185', icon: 'facebook' },
  { name: 'LinkedIn', url: 'https://www.linkedin.com/company/25039841/', icon: 'linkedin' }
];
---

<section id="contacto" class="scroll-mt-20 bg-background py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center animate-on-scroll">
      <h2 class="text-3xl font-bold text-navy sm:text-4xl">
        Contactanos
      </h2>
      <p class="mt-4 text-lg font-light text-text-muted">
        Escribinos para solicitar información, soporte o una demo gratuita.
      </p>
    </div>

    <div class="mt-16 grid gap-12 lg:grid-cols-2">
      <!-- Contact info -->
      <div class="animate-on-scroll" style="animation-delay: 0.1s">
        <div class="space-y-6">
          {contactInfo.map(item => (
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-navy/5">
                {item.icon === 'location' && (
                  <svg class="h-5 w-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                )}
                {item.icon === 'phone' && (
                  <svg class="h-5 w-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                )}
                {item.icon === 'email' && (
                  <svg class="h-5 w-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )}
                {item.icon === 'clock' && (
                  <svg class="h-5 w-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
              </div>
              {item.href ? (
                <a
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="pt-2 text-text transition-colors hover:text-accent"
                >
                  {item.text}
                </a>
              ) : (
                <span class="pt-2 text-text">{item.text}</span>
              )}
            </div>
          ))}
        </div>

        <!-- Social links -->
        <div class="mt-10">
          <div class="flex gap-4">
            {socialLinks.map(social => (
              <a 
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-10 w-10 items-center justify-center rounded-lg bg-navy text-white transition-colors hover:bg-accent"
                aria-label={social.name}
              >
                {social.icon === 'instagram' && (
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                  </svg>
                )}
                {social.icon === 'facebook' && (
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                  </svg>
                )}
                {social.icon === 'linkedin' && (
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                )}
              </a>
            ))}
          </div>
          
          <a 
            href="https://secure.noanet.com.ar/lineaetica" 
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-navy transition-colors hover:text-accent"
          >
            Línea Ética
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Contact form -->
      <div class="animate-on-scroll" style="animation-delay: 0.2s">
        <form 
          id="contact-form"
          action="https://formsubmit.co/contacto@noanet.com.ar" 
          method="POST"
          class="space-y-6"
        >
          <input type="hidden" name="_subject" value="Nuevo contacto desde el sitio web">
          <input type="hidden" name="_captcha" value="false">
          
          <div>
            <label for="name" class="block text-sm font-medium text-navy">Nombre y Apellido</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required
              class="mt-2 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-text transition-colors focus:border-accent focus:outline-none"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-navy">Empresa</label>
            <input 
              type="text" 
              id="company" 
              name="company"
              class="mt-2 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-text transition-colors focus:border-accent focus:outline-none"
            />
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <label for="phone" class="block text-sm font-medium text-navy">Teléfono</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone"
                class="mt-2 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-text transition-colors focus:border-accent focus:outline-none"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-navy">Correo electrónico</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="mt-2 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-text transition-colors focus:border-accent focus:outline-none"
              />
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-navy">Mensaje</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4"
              required
              class="mt-2 block w-full resize-none rounded-lg border border-gray-200 bg-white px-4 py-3 text-text transition-colors focus:border-accent focus:outline-none"
            ></textarea>
          </div>

          <button 
            type="submit"
            class="w-full rounded-full bg-accent py-4 text-base font-bold text-white transition-colors hover:bg-accent-hover"
          >
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }

  #contact-form input:focus,
  #contact-form textarea:focus,
  #contact-form input:focus-visible,
  #contact-form textarea:focus-visible {
    border-color: rgba(228, 2, 45, 0.75);
    box-shadow: none;
    outline: none;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('#contacto .animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
