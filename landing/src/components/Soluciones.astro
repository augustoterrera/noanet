---
import agromovilLogo from '../image/agromovil.png';
import cenitLogo from '../image/cenit.png';
import conectLogo from '../image/conect.png';
import gesperLogo from '../image/gesper.png';

const solutions = [
  {
    title: 'Gesper',
    description: 'Sistema web modular para la gestión total de Recursos Humanos: legajo digital, asistencia, liquidación de sueldos, medicina laboral, capacitación y autogestión.',
    icon: 'users',
    logo: gesperLogo,
    isProduct: true,
    link: 'https://gesper.vercel.app'
  },
  {
    title: 'Agromovil',
    description: 'Sistema para empresas agrícolas que gestiona asistencia, lotes, tareas, remitos, producción y packing en campo, con operación offline y sincronización posterior.',
    icon: 'leaf',
    logo: agromovilLogo,
    isProduct: true,
    link: 'https://agromovil.vercel.app'
  },
  {
    title: 'Cenit',
    description: 'Seguimiento vehicular por GPS para transporte de pasajeros, carga o cuadrillas. Mapa en tiempo real, reportes, eventos configurables e historial de flota.',
    icon: 'map',
    logo: cenitLogo,
    isProduct: true,
    link: 'https://www.noanet.com.ar/cenit/'
  },
  {
    title: 'Conect',
    description: 'Conectividad segura entre puntos de trabajo y sucursales, con infraestructura propia incluso en zonas remotas. Diseño, instalación, administración y mantenimiento de redes.',
    icon: 'globe',
    logo: conectLogo,
    isProduct: false,
    link: '#contacto'
  },
  {
    title: 'Comunicaciones y Networking',
    description: 'Cableado UTP, fibra óptica, vínculos inalámbricos, telefonía LAN/WAN, VPN punto a punto, CCTV y soporte técnico 24 horas, todos los días.',
    icon: 'network',
    isProduct: false,
    link: '#contacto'
  },
  {
    title: 'Data Center',
    description: 'Administración de servidores y bases de datos, hosting, housing, almacenamiento, backup, restore y soluciones de energía con UPS y grupos electrógenos.',
    icon: 'server',
    isProduct: false,
    link: '#contacto'
  },
];
---

<section id="soluciones" class="scroll-mt-20 bg-background-alt py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center animate-on-scroll">
      <h2 class="text-3xl font-bold text-navy sm:text-4xl">
        Nuestras soluciones
      </h2>
      <p class="mt-4 text-lg font-light text-text-muted">
        Tecnología, desarrollo de software, conectividad, data center y soporte
        continuo para cubrir necesidades empresariales reales.
      </p>
    </div>

    <!-- Solutions grid -->
    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {solutions.map((solution, index) => (
        <article 
          class="solution-card animate-on-scroll group relative overflow-hidden rounded-xl bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <!-- Product badge -->
          {solution.isProduct && (
            <span class="absolute right-4 top-4 rounded-full bg-accent px-3 py-1 text-xs font-bold text-white">
              Producto propio
            </span>
          )}

          <!-- Top border on hover -->
          <div class="absolute left-0 right-0 top-0 h-1 origin-left scale-x-0 bg-accent transition-transform duration-300 group-hover:scale-x-100"></div>

          <!-- Logo / Icon and title -->
          {solution.logo ? (
            <div class="mb-5 flex min-h-14 items-center justify-start pr-28">
              <img
                src={solution.logo.src}
                alt={`Logo ${solution.title}`}
                class="max-h-10 max-w-[180px] object-contain"
                width={solution.logo.width}
                height={solution.logo.height}
              />
            </div>
          ) : (
            <div class="mb-4 flex items-center gap-3">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-navy/5">
                {solution.icon === 'users' && (
                  <svg class="h-6 w-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                )}
                {solution.icon === 'leaf' && (
                  <svg class="h-6 w-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                  </svg>
                )}
                {solution.icon === 'globe' && (
                  <svg class="h-6 w-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                )}
                {solution.icon === 'network' && (
                  <svg class="h-6 w-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />
                  </svg>
                )}
                {solution.icon === 'server' && (
                  <svg class="h-6 w-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
                  </svg>
                )}
                {solution.icon === 'map' && (
                  <svg class="h-6 w-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                )}
                {solution.icon === 'support' && (
                  <svg class="h-6 w-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636a9 9 0 010 12.728m-12.728 0a9 9 0 010-12.728m9.9 2.828a5 5 0 010 7.072m-7.072 0a5 5 0 010-7.072M12 13a1 1 0 100-2 1 1 0 000 2z" />
                  </svg>
                )}
                {solution.icon === 'code' && (
                  <svg class="h-6 w-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 18l6-6-6-6M8 6l-6 6 6 6" />
                  </svg>
                )}
              </div>
              <h3 class="text-xl font-bold text-navy">{solution.title}</h3>
            </div>
          )}

          <!-- Content -->
          <p class={`${solution.logo ? '' : 'mt-2'} text-sm font-light leading-relaxed text-text-muted`}>
            {solution.description}
          </p>

          <!-- Link -->
          <a 
            href={solution.link} 
            class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent transition-colors hover:text-accent-hover"
          >
            Conocer más
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('#soluciones .animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
