---
const stats = [
  { value: '2.500 km', label: 'de red propia' },
  { value: '96', label: 'sitios conectados' },
  { value: '190', label: 'servicios activos' },
  { value: '24/7', label: 'disponibilidad continua' },
];
---

<section id="infraestructura" class="bg-navy py-14 lg:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[0.85fr_1fr] lg:items-center">
      <div class="animate-on-scroll">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent">Infraestructura propia</span>
        <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">
          Conectividad empresarial incluso en zonas remotas
        </h2>
        <p class="mt-4 max-w-2xl font-light leading-relaxed text-white/70">
          Nuestra red permite conectar puntos de trabajo y sucursales con servicios
          dedicados, seguros y administrados por equipos técnicos especializados.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-px overflow-hidden rounded-lg bg-white/10 md:grid-cols-4">
        {stats.map((stat, index) => (
          <div
            class="animate-on-scroll bg-navy-dark p-5 text-center"
            style={`animation-delay: ${index * 0.08}s`}
          >
            <div class="whitespace-nowrap text-2xl font-black text-white sm:text-3xl">{stat.value}</div>
            <div class="mt-2 text-xs font-medium uppercase tracking-[0.08em] text-white/55">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }

  .animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('#infraestructura .animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
