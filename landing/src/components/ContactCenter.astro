---
import { Image } from 'astro:assets';
import OmnicanalImg from '../image/omnicanal.png';

const features = [
  'Customer service',
  'Help Desk',
  'Encuestas',
  'Gestión de mora',
  'Canales digitales'
];

const channels = [
  'Messenger',
  'WhatsApp',
  'Web Chat',
  'SMS',
  'RCS',
  'Viber',
  'Live',
  'Vocalcom'
];
---

<section id="contact-center" class="bg-background py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Content -->
      <div class="animate-on-scroll">
        <h2 class="text-2xl font-bold text-navy sm:text-3xl">
          Contact Center
        </h2>
        <p class="mt-4 font-light leading-relaxed text-text-muted">
          Brindamos servicios receptivos y campañas salientes para empresas:
          customer service, Help Desk, encuestas, seguimiento de campañas,
          gestión de morosos y mora temprana.
        </p>
        <p class="mt-4 font-light leading-relaxed text-text-muted">
          Acompañamos la migración hacia canales digitales con frentes de atención
          asistidos y no asistidos, integrando asistentes virtuales como Agentbot y operadores en vivo.
        </p>
        
        <!-- Feature pills -->
        <div class="mt-6 flex flex-wrap gap-3">
          {features.map(feature => (
            <span class="inline-flex items-center rounded-full border border-navy/20 px-4 py-2 text-sm font-medium text-navy">
              {feature}
            </span>
          ))}
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          {channels.map(channel => (
            <span class="inline-flex items-center rounded-full bg-navy/5 px-3 py-1.5 text-xs font-medium text-text-muted">
              {channel}
            </span>
          ))}
        </div>
      </div>

      <!-- Image -->
      <div class="animate-on-scroll flex justify-center lg:justify-end" style="animation-delay: 0.2s">
        <Image
          src={OmnicanalImg}
          alt="Atención omnicanal para clientes por teléfono, chat y canales digitales"
          class="h-80 w-full max-w-2xl object-contain lg:h-96"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('#contact-center .animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
