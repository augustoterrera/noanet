---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Nosotros from '../components/Nosotros.astro';
import Infraestructura from '../components/Infraestructura.astro';
import Soluciones from '../components/Soluciones.astro';
import ObrasReferencia from '../components/ObrasReferencia.astro';
import ContactCenter from '../components/ContactCenter.astro';
import Clientes from '../components/Clientes.astro';
import NoanetWifi from '../components/NoanetWifi.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
