---
function rand(seed: number): number {
  const x = Math.sin(seed + 1) * 10000;
  return x - Math.floor(x);
}

const COLS = 7;
const ROWS = 5;
const W = 1440;
const H = 820;
const PX = 60;  // perturbación horizontal por punto
const PY = 48;  // perturbación vertical por punto

// Grilla de puntos con perturbación (los bordes no se mueven)
const pts: [number, number][][] = Array.from({ length: ROWS + 1 }, (_, r) =>
  Array.from({ length: COLS + 1 }, (_, c) => {
    const baseX = (c / COLS) * W;
    const baseY = (r / ROWS) * H;
    const border = c === 0 || c === COLS || r === 0 || r === ROWS;
    const s = r * 100 + c;
    return [
      baseX + (border ? 0 : (rand(s * 2.31) - 0.5) * 2 * PX),
      baseY + (border ? 0 : (rand(s * 3.71) - 0.5) * 2 * PY),
    ] as [number, number];
  })
);

// Genera un path por parcela (cuadrilátero cerrado)
const parcelas = Array.from({ length: ROWS }, (_, r) =>
  Array.from({ length: COLS }, (_, c) => {
    const [x0, y0] = pts[r][c];
    const [x1, y1] = pts[r][c + 1];
    const [x2, y2] = pts[r + 1][c + 1];
    const [x3, y3] = pts[r + 1][c];
    const d = `M ${x0.toFixed(1)},${y0.toFixed(1)} L ${x1.toFixed(1)},${y1.toFixed(1)} L ${x2.toFixed(1)},${y2.toFixed(1)} L ${x3.toFixed(1)},${y3.toFixed(1)} Z`;
    const opacity = (0.07 + rand(r * 13 + c * 7) * 0.05).toFixed(3);
    return { d, opacity };
  })
).flat();
---

<section class="hero relative isolate overflow-hidden">

  <!-- Líneas topográficas: cubren toda la sección hero -->
  <svg
    class="hero-wind"
    viewBox="0 0 1440 820"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g>
      {parcelas.map((p) => (
        <path
          class="wind-line"
          d={p.d}
          fill="none"
          stroke-width="0.8"
          opacity={p.opacity}
        />
      ))}
    </g>
  </svg>

  <div class="hero-glow"></div>

  <div class="container hero-inner">

    <h1 class="hero-title font-display font-extrabold tracking-[-0.03em] leading-[1.02]">
      Sabé qué pasa en cada lote.<br>
      En <span class="hero-word-accent">tiempo real.</span>
    </h1>

    <div class="hero-bottom">
      <p class="hero-sub text-[var(--fg-muted)] leading-[1.65] max-w-[500px]">
        Agromovil digitaliza la producción agrícola y el control de personal desde un portal web, con operación en campo desde el celular. Georreferencia tareas, valida identidad con reconocimiento biométrico, usa tecnología NFC, funciona offline cuando se requiere y soporta múltiples productos y empresas.
      </p>

      <div class="hero-actions">
        <a href="#contacto" class="btn btn-primary">
          Solicitar una demo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="#modulos" class="btn btn-ghost">
          Ver módulos
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    min-height: 88vh;
    display: flex;
    flex-direction: column;
  }

  .hero-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: 8rem;
    padding-bottom: 7rem;
    gap: 2.5rem;
    position: relative;
    z-index: 1;
  }

  /* Líneas topográficas sobre fondo completo del hero */
  .hero-wind {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 8%,
      black 68%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 8%,
      black 68%,
      transparent 100%
    );
  }

  .hero-title {
    font-size: clamp(40px, 5.5vw, 72px);
    max-width: 18ch;
    position: relative;
    z-index: 1;
  }

  .hero-word-serif {
    font-family: Georgia, serif;
    font-style: italic;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .hero-word-accent {
    color: var(--accent);
  }

  .hero-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 900px) {
    .hero-bottom {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 3rem;
    }
  }

  .hero-sub {
    font-size: clamp(15px, 1.3vw, 17px);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  /* Fade superior */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 10px;
    background: linear-gradient(to bottom, var(--bg) 0%, transparent 100%);
    z-index: 2;
    pointer-events: none;
  }

  /* Fade inferior — elimina el corte brusco */
  .hero::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 140px;
    background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
    z-index: 2;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    inset: -20% 0 auto 0;
    height: 65%;
    z-index: 0;
    background: var(--glow);
    pointer-events: none;
    opacity: 0.75;
    mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
  }
</style>
