---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import module1 from '@/images/modulo1.webp'
import module2 from '@/images/modulo2.webp'
import activitiesWeb from '@/images/web.webp';
import activitiesApp from '@/images/app.webp';
import activitiesAsignacion from '@/images/asignacion.webp';
import activitiesAsistencia from '@/images/asistencia.webp';
import activitiesJornada from '@/images/gestion_jornada.webp';
import remitoMovimientos from '@/images/remito_movimientos.webp';
import remitoOficial from '@/images/remito_oficial.webp';
import remitoInterno from '@/images/remito_interno.webp';
import cosecha from '@/images/cosecha.webp';
import packing from '@/images/packing.webp';


type ModuleImage = {
  src: ImageMetadata;
  alt: string;
  label: string;
  featured?: boolean;
};

type Module = {
  tag: string;
  label: string;
  title: string;
  desc: string;
  features: string[];
  images?: ModuleImage[];
};

const modules: Module[] = [
  {
    tag: '01',
    label: 'Base',
    title: 'Control de Personal en Campo',
    desc: 'Registrá ingresos, asistencia, jornales y novedades desde el celular, usando distintos métodos de reconocimiento como QR, NFC o biometría. Puede trabajarse offline y enviar los datos al portal web de Agromovil bajo demanda cuando haya conectividad.',
    features: ['Vista gráfica del personal por día', 'Reconocimiento por QR, NFC o biometría', 'Registro desde celular', 'Trabajo offline y envío bajo demanda'],
    images: [
      {
        src: module1,
        alt: 'Vista gráfica del personal trabajando por día en el portal web de Agromovil',
        label: 'Portal web',
      },
    ],
  },
  {
    tag: '02',
    label: 'Base',
    title: 'Gestión de Lotes y Parcelas',
    desc: 'Organizá tu establecimiento digitalmente. Definí lotes, cultivos activos.',
    features: ['Mapa y delimitación de lotes', 'Rendimientos por parcela'],
    images: [
      {
        src: module2,
        alt: 'Mapa del portal web con lotes y parcelas delimitadas por colores',
        label: 'Mapa de lotes',
      },
    ],
  },
  {
    tag: '03',
    label: '',
    title: 'Registro de Actividades Agrícolas',
    desc: 'Documentá labores culturales y cosecha desde el celular o desde la PC, adaptándose a cada proceso. La información queda disponible en Agromovil para consultar trazabilidad, campañas y avances sin depender de planillas ni recargas manuales.',
    features: ['Labores culturales', 'Cosecha', 'Trazabilidad completa'],
    images: [
      {
        src: activitiesWeb,
        alt: 'Portal web de Agromovil para consultar registros de actividades agrícolas',
        label: 'Web',
        featured: true,
      },
      {
        src: activitiesApp,
        alt: 'Pantalla inicial de la app móvil de Agromovil',
        label: 'App',
      },
      {
        src: activitiesAsignacion,
        alt: 'Pantalla móvil de asignación de actividad agrícola a un empleado',
        label: 'Asignación',
      },
      {
        src: activitiesAsistencia,
        alt: 'Pantalla móvil de registro de asistencia de empleado',
        label: 'Asistencia',
      },
      {
        src: activitiesJornada,
        alt: 'Pantalla móvil de gestión de jornada en Agromovil',
        label: 'Jornada',
      },
    ],
  },
  {
    tag: '04',
    label: '',
    title: 'Remitos y Movimientos',
    desc: 'Registrá desde el celular remitos internos y remitos con número oficial en forma digital, evitando papeles y minimizando errores. Los remitos generados desde la app quedan vinculados a la producción registrada en las actividades del paso anterior. La recepción y gestión de stock se realiza en la web con los datos enviados desde el celular.',
    features: ['Emisión de remitos digitales (internos y oficial)', 'Vinculación con producción registrada', 'Recepción de mercadería', 'Gestión de stock (fresco, IQF)'],
    images: [
      {
        src: remitoMovimientos,
        alt: 'Pantalla móvil de movimientos de remito en Agromovil',
        label: 'Movimiento',
      },
      {
        src: remitoOficial,
        alt: 'Pantalla móvil de remito oficial en Agromovil',
        label: 'Remito Oficial',
      },
      {
        src: remitoInterno,
        alt: 'Pantalla móvil de remito interno en Agromovil',
        label: 'Remito Interno',
      },
    ],
  },
  {
    tag: '05',
    label: '',
    title: 'Cosecha y Producción',
    desc: 'Registrá rendimientos, calidad y destino de la producción. La información permite crear reportes personalizados según la necesidad de cada cliente e integrarse con Power BI para mejorar el análisis y la toma de decisiones.',
    features: ['Rendimientos por lote', 'Calidad', 'Destino de producción', 'Comparativa por campaña'],
    images: [
      {
        src: cosecha,
        alt: 'Reporte web de cosecha y producción con gráfico por lote',
        label: 'Cosecha y produccion',
      },
    ],
  },
  {
    tag: '06',
    label: '',
    title: 'Packing en Campo',
    desc: 'Gestioná el empaque directamente en el establecimiento. Controlá bins, envases, calidad por proceso y despachos, con trazabilidad completa desde la cosecha hasta la salida del producto.',
    features: ['Control de bins y envases', 'Registro de calidad por proceso', 'Trazabilidad cosecha-empaque', 'Despachos'],
    images: [
      {
        src: packing,
        alt: 'Diagrama de procesos de packing en campo dentro de Agromovil',
        label: 'Packing',
      },
    ],
  },
  {
    tag: '07',
    label: 'Opcional',
    title: 'Integración con Sistemas de RRHH',
    desc: 'Los datos impactan primero en Agromovil. En empresas que usan Gesper, el software web de RRHH de Noanet para gestión de personal, asistencia y liquidación de haberes, la información puede enviarse bajo demanda. También puede adaptarse a otros sistemas de RRHH.',
    features: ['Agromovil como sistema central', 'Integración con Gesper', 'Adaptable a otros sistemas de RRHH', 'Envío bajo demanda'],
  },
];
---

<section class="section" id="modulos">
  <div class="container">

    <div class="section-head">
      <span class="section-eyebrow">Modulos</span>
      <h2 class="h2">Todo lo que pasa en el campo, <span class="accent">en tu sistema.</span></h2>
      <p class="section-sub max-w-lg mx-auto">Agromovil centraliza la operación agrícola en un portal web y permite registrar el trabajo de campo desde el celular. Sin papeles, sin señal obligatoria y con envío de datos bajo demanda.</p>
    </div>

    <div class="divide-y divide-[var(--border)]">
      {modules.map((m, mi) => {
        const hasImages = Boolean(m.images?.length);
        const hasGallery = Boolean(m.images && m.images.length > 1);
        const hasFeaturedImage = Boolean(m.images?.some((image) => image.featured));

        return (
        <div
          class:list={[
            'module-row py-12 nav:py-16',
            hasImages ? 'has-media' : 'no-media',
          ]}
        >

          <div class="module-heading">
            <div class="module-kicker">
              <span>{m.tag}</span>
              {m.label && (
                <span class="module-label">{m.label}</span>
              )}
            </div>
            <h3 class="module-title">
              {m.title}
            </h3>
          </div>

          <div class="module-body">
            <p class="module-desc">{m.desc}</p>

            <dl class="module-features">
              {m.features.map((f, fi) => (
                <div class="module-feature">
                  <dt>
                    {m.tag}.{String(fi + 1).padStart(1, '0')}
                  </dt>
                  <dd>{f}</dd>
                </div>
              ))}
            </dl>
          </div>

          {hasImages && (
            <>
              {hasGallery ? (
                <div class="module-media module-gallery">
                  <div class="module-gallery-stage">
                    <button
                      type="button"
                      data-lightbox-open={`module-gallery-${mi}`}
                      aria-label={`Ver capturas de ${m.title}`}
                      class="module-shot module-gallery-preview is-active overflow-hidden rounded-lg border border-[var(--border)] bg-[var(--bg-elev)]"
                    >
                      <Image
                        src={m.images[0].src}
                        alt={m.images[0].alt}
                        width={520}
                        widths={[360, 520, 720, 960]}
                        loading="lazy"
                        sizes="(min-width: 1240px) 390px, (min-width: 900px) 30vw, calc(100vw - 56px)"
                        class="h-full w-full object-contain"
                      />
                      <span class="module-gallery-more">
                        + ver {m.images.length} capturas
                      </span>
                    </button>
                  </div>

                  <p class="module-gallery-count">
                    {m.images.length} capturas disponibles
                  </p>
                </div>
              ) : (
                <div class="module-media module-single">
                  {m.images?.map((image, ii) => {
                    const imageDialogId = `module-image-${mi}-${ii}`;

                    return (
                      <button
                        type="button"
                        data-lightbox-open={imageDialogId}
                        aria-label={`Ampliar imagen de ${image.label} para ${m.title}`}
                        class="module-shot overflow-hidden rounded-lg border border-[var(--border)] bg-[var(--bg-elev)]"
                      >
                        <Image
                          src={image.src}
                          alt={image.alt}
                          width={420}
                          widths={[260, 360, 420, 640, 840]}
                          loading="lazy"
                          sizes="(min-width: 1240px) 360px, (min-width: 900px) 28vw, calc(100vw - 56px)"
                          class="h-full w-full object-contain"
                        />
                        <span class="module-shot-zoom" aria-hidden="true">
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="7"></circle>
                            <path d="m16.5 16.5 4 4"></path>
                            <path d="M11 8v6"></path>
                            <path d="M8 11h6"></path>
                          </svg>
                        </span>
                      </button>
                    );
                  })}
                </div>
              )}

              {hasGallery ? (
                <dialog
                  id={`module-gallery-${mi}`}
                  class="module-lightbox module-gallery-lightbox"
                  data-module-dialog
                  aria-labelledby={`module-gallery-title-${mi}`}
                >
                  <div class="module-lightbox-panel">
                    <div class="module-lightbox-bar">
                      <h3 id={`module-gallery-title-${mi}`} class="module-lightbox-title">{m.title}</h3>
                      <button
                        type="button"
                        class="module-lightbox-close"
                        data-lightbox-close
                        aria-label="Cerrar capturas ampliadas"
                      >
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round">
                          <path d="M18 6 6 18"></path>
                          <path d="m6 6 12 12"></path>
                        </svg>
                      </button>
                    </div>
                    <div class:list={['module-lightbox-gallery', !hasFeaturedImage && 'is-phone-gallery']}>
                      {m.images?.filter((image) => image.featured).map((image) => (
                        <figure class="module-lightbox-featured-item">
                          <Image
                            src={image.src}
                            alt={image.alt}
                            width={1716}
                            widths={[900, 1180, 1408, 1716]}
                            loading="lazy"
                            sizes="min(1220px, calc(100vw - 64px))"
                            class="w-full"
                          />
                          <figcaption>{image.label}</figcaption>
                        </figure>
                      ))}
                      <div class="module-lightbox-gallery-grid">
                        {m.images?.filter((image) => !image.featured).map((image) => (
                          <figure class="module-lightbox-gallery-item">
                            <Image
                              src={image.src}
                              alt={image.alt}
                              width={720}
                              widths={[320, 420, 640, 720, 960]}
                              loading="lazy"
                              sizes="(min-width: 900px) 30vw, calc(100vw - 64px)"
                              class="h-full w-full object-contain"
                            />
                            <figcaption>{image.label}</figcaption>
                          </figure>
                        ))}
                      </div>
                    </div>
                  </div>
                </dialog>
              ) : m.images?.map((image, ii) => {
                const imageDialogId = `module-image-${mi}-${ii}`;
                const imageTitleId = `module-image-title-${mi}-${ii}`;

                return (
                  <dialog
                    id={imageDialogId}
                    class="module-lightbox"
                    data-module-dialog
                    aria-labelledby={imageTitleId}
                  >
                    <div class="module-lightbox-panel">
                      <div class="module-lightbox-bar">
                        <h3 id={imageTitleId} class="module-lightbox-title">{m.title} · {image.label}</h3>
                        <button
                          type="button"
                          class="module-lightbox-close"
                          data-lightbox-close
                          aria-label="Cerrar imagen ampliada"
                        >
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round">
                            <path d="M18 6 6 18"></path>
                            <path d="m6 6 12 12"></path>
                          </svg>
                        </button>
                      </div>
                      <div class="module-lightbox-image">
                        <Image
                          src={image.src}
                          alt={image.alt}
                          width={1180}
                          widths={[640, 960, 1180, 1408, 1716]}
                          loading="lazy"
                          sizes="min(92vw, 1180px)"
                          class="h-full w-full object-contain"
                        />
                      </div>
                    </div>
                  </dialog>
                );
              })}
            </>
          )}

        </div>
      )})}
    </div>

  </div>
</section>

<style>
  .module-row {
    display: grid;
    gap: 2rem;
    align-items: start;
  }

  .module-heading,
  .module-body {
    display: grid;
    min-width: 0;
  }

  .module-heading {
    gap: 1.35rem;
  }

  .module-body {
    gap: 1.35rem;
  }

  .module-kicker {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--accent);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .module-label {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 3px 7px;
    color: var(--accent);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .module-title {
    max-width: 440px;
    color: var(--fg);
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .module-desc {
    max-width: 520px;
    margin: 0;
    color: var(--fg-muted);
    font-size: 17px;
    line-height: 1.6;
  }

  .module-features {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    max-width: 520px;
  }

  .module-feature {
    display: flex;
    min-width: 0;
    align-items: baseline;
    gap: 4px;
    border-radius: 8px;
    padding: 10px 12px;
    color: var(--fg-muted);
    background: var(--card);
    font-size: 14px;
    line-height: 1.25;
  }

  .module-feature dt,
  .module-feature dd {
    min-width: 0;
  }

  .module-feature dt {
    flex: 0 0 auto;
    color: var(--fg-muted);
    font-weight: 600;
  }

  .module-feature dd {
    white-space: normal;
  }

  .module-media {
    min-width: 0;
    width: min(100%, 430px);
  }

  .module-single .module-shot {
    aspect-ratio: 16 / 10;
    width: 100%;
  }

  .module-gallery {
    display: grid;
    gap: 12px;
  }

  .module-gallery-stage {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 8px;
  }

  @media (min-width: 900px) {
    .module-row.has-media {
      grid-template-columns: minmax(320px, 0.92fr) minmax(340px, 0.88fr);
      column-gap: clamp(2.5rem, 7vw, 6rem);
    }

    .module-row.has-media .module-heading {
      grid-column: 1;
    }

    .module-row.has-media .module-body {
      grid-column: 1;
    }

    .module-row.no-media {
      grid-template-columns: minmax(320px, 0.92fr) minmax(0, 0.88fr);
      column-gap: clamp(2.5rem, 7vw, 6rem);
    }

    .module-row.no-media .module-heading {
      grid-column: 1;
    }

    .module-row.no-media .module-body {
      grid-column: 2;
    }

    .module-media {
      grid-column: 2;
      grid-row: 1 / span 2;
      justify-self: end;
      width: min(100%, 425px);
    }
  }

  @media (max-width: 560px) {
    .module-features {
      grid-template-columns: 1fr;
    }

    .module-feature dd {
      white-space: normal;
    }
  }


  .module-gallery-preview {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  .module-gallery-preview.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .module-gallery-more {
    position: absolute;
    right: 14px;
    bottom: 12px;
    z-index: 1;
    border-radius: 999px;
    padding: 8px 13px;
    color: #fff;
    background: rgba(7, 20, 7, 0.72);
    box-shadow: 0 12px 32px -18px rgba(0, 0, 0, 0.8);
    font-size: 13px;
    font-weight: 700;
    line-height: 1;
    backdrop-filter: blur(10px);
  }

  .module-gallery-count {
    margin: -2px 0 0;
    color: var(--fg-dim);
    font-size: 14px;
    line-height: 1.3;
    text-align: center;
  }

  .module-shot {
    position: relative;
    display: block;
    width: 100%;
    background: #f6f7f4;
    box-shadow:
      0 24px 80px -48px rgba(0, 0, 0, 0.55),
      0 1px 0 rgba(255, 255, 255, 0.04) inset;
  }

  .module-shot::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(to right, var(--bg) 0%, transparent 8%, transparent 92%, var(--bg) 100%),
      linear-gradient(to bottom, transparent 72%, var(--bg) 100%);
    opacity: 0.18;
  }

  [data-theme="light"] .module-shot {
    box-shadow:
      0 28px 90px -58px rgba(13, 26, 13, 0.42),
      0 1px 0 rgba(255, 255, 255, 0.8) inset;
  }

  [data-theme="light"] .module-shot::after {
    opacity: 0.28;
  }

  .module-shot {
    cursor: zoom-in;
    padding: 0;
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .module-shot:hover,
  .module-shot:focus-visible {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  .module-shot:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .module-shot-zoom {
    position: absolute;
    top: 9px;
    right: 9px;
    z-index: 1;
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    color: #fff;
    background: rgba(7, 20, 7, 0.72);
    box-shadow: 0 12px 32px -18px rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
  }

  .module-lightbox {
    width: min(1180px, calc(100vw - 32px));
    max-width: none;
    max-height: calc(100vh - 32px);
    padding: 0;
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    color: var(--fg);
    background: var(--bg-elev);
    box-shadow: 0 40px 120px -52px rgba(0, 0, 0, 0.78);
  }

  .module-lightbox::backdrop {
    background: rgba(3, 8, 3, 0.72);
    backdrop-filter: blur(8px);
  }

  .module-lightbox-panel {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    max-height: calc(100vh - 32px);
  }

  .module-lightbox-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }

  .module-lightbox-title {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--fg);
  }

  .module-lightbox-close {
    display: grid;
    width: 38px;
    height: 38px;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg);
    background: transparent;
    transition:
      border-color 180ms ease,
      background 180ms ease;
  }

  .module-lightbox-close:hover,
  .module-lightbox-close:focus-visible {
    border-color: var(--border-strong);
    background: var(--card);
  }

  .module-lightbox-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .module-lightbox-image {
    display: grid;
    min-height: 0;
    padding: 16px;
    place-items: center;
  }

  .module-lightbox-image :global(img) {
    max-height: calc(100vh - 120px);
  }

  .module-gallery-lightbox {
    width: min(1320px, calc(100vw - 32px));
  }

  .module-lightbox-gallery {
    max-height: calc(100vh - 92px);
    overflow: auto;
    padding: 16px;
  }

  .module-lightbox-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 14px;
  }

  .module-lightbox-gallery.is-phone-gallery .module-lightbox-gallery-grid {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
    align-items: start;
  }

  .module-lightbox-featured-item + .module-lightbox-gallery-grid {
    margin-top: 14px;
  }

  .module-lightbox-featured-item {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #f6f7f4;
  }

  .module-lightbox-featured-item :global(img) {
    display: block;
    width: 100%;
    height: auto;
    padding: 12px;
  }

  .module-lightbox-gallery-item {
    display: grid;
    grid-template-rows: minmax(300px, 42vh) auto;
    min-height: 0;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #f6f7f4;
  }

  .module-lightbox-gallery-item :global(img) {
    padding: 12px;
  }

  .module-lightbox-gallery.is-phone-gallery .module-lightbox-gallery-item {
    grid-template-rows: minmax(560px, calc(100vh - 180px)) auto;
  }

  .module-lightbox-gallery.is-phone-gallery .module-lightbox-gallery-item :global(img) {
    padding: 14px;
  }

  .module-lightbox-featured-item figcaption,
  .module-lightbox-gallery-item figcaption {
    border-top: 1px solid var(--border);
    padding: 10px 12px;
    color: var(--fg);
    background: var(--bg-elev);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.2;
  }

  @media (max-width: 760px) {
    .module-lightbox-gallery-item {
      grid-template-rows: minmax(260px, 48vh) auto;
    }

    .module-lightbox-gallery.is-phone-gallery .module-lightbox-gallery-item {
      grid-template-rows: minmax(520px, calc(100vh - 160px)) auto;
    }
  }
</style>

<script>
  const openButtons = document.querySelectorAll<HTMLButtonElement>('[data-lightbox-open]');
  const dialogs = document.querySelectorAll<HTMLDialogElement>('[data-module-dialog]');

  openButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const dialogId = button.dataset.lightboxOpen;
      const dialog = dialogId ? document.getElementById(dialogId) : null;

      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
      }
    });
  });

  dialogs.forEach((dialog) => {
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });

    dialog.querySelectorAll<HTMLButtonElement>('[data-lightbox-close]').forEach((button) => {
      button.addEventListener('click', () => dialog.close());
    });
  });
</script>
