---
import { Image } from 'astro:assets';
import agromovilLogo from '../assets/agromovil-logo.png';

const product = ['Módulos', 'Integraciones', 'Offline bajo demanda', 'Seguridad'];
const company = ['Noanet', 'Clientes', 'Casos de éxito', 'Contacto'];
const resources = ['Centro de ayuda', 'Documentación', 'Estado del servicio', 'Blog'];
---

<footer class="border-t border-[var(--border)] pt-[72px] pb-10 bg-[var(--bg)]">
  <div class="container">

    <div class="grid grid-cols-2 nav:grid-cols-[2fr_1fr_1fr_1fr] gap-12 mb-14">
      <!-- Brand -->
      <div class="col-span-2 nav:col-span-1">
        <Image src={agromovilLogo} alt="Agromovil" class="w-[260px] max-w-full h-auto mb-5" />
        <p class="text-sm text-[var(--fg-muted)] max-w-[280px] leading-[1.55]">
          Gestión digital de operaciones en campo. Del celular al portal web, sin papeles.
        </p>
      </div>

      <!-- Producto -->
      <div>
        <h5 class="text-[12px] font-bold tracking-[0.08em] uppercase text-[var(--fg-dim)] mb-4">Producto</h5>
        <ul class="flex flex-col gap-[10px] list-none p-0">
          {product.map((item) => (
            <li><a href={item === 'Módulos' ? '#modulos' : '#'} class="text-sm text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors duration-150">{item}</a></li>
          ))}
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <h5 class="text-[12px] font-bold tracking-[0.08em] uppercase text-[var(--fg-dim)] mb-4">Empresa</h5>
        <ul class="flex flex-col gap-[10px] list-none p-0">
          {company.map((item) => (
            <li><a href={item === 'Contacto' ? '#contacto' : '#'} class="text-sm text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors duration-150">{item}</a></li>
          ))}
        </ul>
      </div>

      <!-- Recursos -->
      <div>
        <h5 class="text-[12px] font-bold tracking-[0.08em] uppercase text-[var(--fg-dim)] mb-4">Recursos</h5>
        <ul class="flex flex-col gap-[10px] list-none p-0">
          {resources.map((item) => (
            <li><a href="#" class="text-sm text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors duration-150">{item}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-7 border-t border-[var(--border)] flex justify-between flex-wrap gap-3 text-[13px] text-[var(--fg-dim)]">
      <span>© 2026 Noanet. Todos los derechos reservados.</span>
      <span>Términos · Privacidad · Cookies</span>
    </div>

  </div>
</footer>
