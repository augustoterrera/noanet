---
import { Image } from 'astro:assets';
import sideraLogo from '@/images/sidera.jpg'
import argentiLemonLogo from '../../../shared-assets/clients/argenti-lemon.png';
import diagonalCitrusLogo from '../../../shared-assets/clients/diagonal-citrus-recortada.png';
import grupoMpLogo from '../../../shared-assets/clients/grupo-mp.svg';
import trapaniLogo from '../../../shared-assets/clients/trapani.svg';

const clients = [
  { logo: trapaniLogo, alt: 'Trapani', cls: 'h-9 w-auto', width: 160 },
  { logo: diagonalCitrusLogo, alt: 'Diagonal Citrus', cls: 'h-12 w-auto', width: 162 },
  { logo: argentiLemonLogo, alt: 'Argenti Lemon', cls: 'h-12 w-auto', width: 205 },
  { logo: grupoMpLogo, alt: 'Grupo MP', cls: 'h-12 w-auto', width: 64, label: 'GRUPO MP' },
  { logo: sideraLogo, alt: 'Sidera S.R.L', cls: 'h-12 w-auto', width: 48 },
];
---

<div class="clients-static flex items-center justify-center flex-wrap gap-12 py-3 px-8">
  {clients.map((c) => (
    <div class="clients-item shrink-0 flex items-center justify-center px-3">
      <Image
        src={c.logo}
        alt={c.alt}
        width={c.width}
        quality={68}
        class={`${c.cls} object-contain`}
        loading="lazy"
      />
      {c.label && (
        <span class="ml-2 text-sm font-bold tracking-widest whitespace-nowrap text-[var(--fg-muted)]">
          {c.label}
        </span>
      )}
    </div>
  ))}
</div>

<style>
  .clients-item {
    opacity: 0.75;
    transition: opacity 300ms linear;
  }
  .clients-item:hover {
    opacity: 1;
  }
</style>
