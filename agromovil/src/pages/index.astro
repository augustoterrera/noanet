---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Modules from '../components/Modules.astro';
import Technologies from '../components/Technologies.astro';
import Clients from '../components/Clients.astro';
import Reasons from '../components/Reasons.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const seo = {
  title: 'Agromovil | Software agrícola para campo, personal, lotes y producción',
  description:
    'Agromovil centraliza la gestión agrícola desde celular y portal web: control de personal, lotes, actividades, remitos, cosecha, packing, stock, trazabilidad, operación offline e integraciones de RRHH.',
  canonicalPath: '/agromovil/',
  keywords: [
    'software agricola',
    'gestion de campo',
    'control de personal agricola',
    'gestion de lotes',
    'remitos digitales campo',
    'trazabilidad agricola',
    'cosecha y produccion',
    'packing en campo',
    'Agromovil Noanet',
  ],
};
---

<Layout {...seo}>
  <Nav />
  <main>
    <Hero />
    <section id="clientes" class="py-20">
      <div class="container text-center mb-10">
        <p class="text-sm font-semibold uppercase tracking-widest text-[var(--accent)] mb-3">Clientes</p>
        <h2 class="text-3xl font-bold text-[var(--fg)]">Productores que ya digitalizaron su campo</h2>
      </div>
      <Clients />
    </section>
    <Modules />
    <Technologies />
    <Reasons />
    <Contact />
  </main>
  <Footer />
</Layout>
