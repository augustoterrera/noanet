---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Agromovil — Gestión digital de operaciones en campo',
  description = 'Agromovil centraliza la operación en campo desde un portal web y permite registrar tareas, personal, remitos, producción y stock desde el celular, con trabajo offline y envío de datos bajo demanda.',
} = Astro.props;
---
<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,400;1,500;1,600;1,700&family=Mulish:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <!-- Prevent FOUC: aplica tema guardado antes del primer paint -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('agromovil-theme') || 'light';
        document.documentElement.setAttribute('data-theme', saved);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
