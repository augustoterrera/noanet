---
const product = [
  { label: 'Módulos', href: '#modulos' },
  { label: 'Autogestión', href: '#modulos' },
  { label: 'Liquidación de haberes', href: '#modulos' },
  { label: 'Seguridad', href: '#razones' },
];
const company = [
  { label: 'Noanet', href: '#contacto' },
  { label: 'Clientes', href: '#clientes' },
  { label: 'Casos de éxito', href: '#clientes' },
  { label: 'Contacto', href: '#contacto' },
];
const resources = [
  { label: 'Demo personalizada', href: '#contacto' },
  { label: 'Asesoramiento comercial', href: '#contacto' },
  { label: 'Módulos recomendados', href: '#contacto' },
  { label: 'Propuesta sin compromiso', href: '#contacto' },
];
---

<footer class="border-t border-[var(--border)] pt-[72px] pb-10 bg-[var(--bg)]">
  <div class="container">

    <div class="grid grid-cols-2 nav:grid-cols-[2fr_1fr_1fr_1fr] gap-12 mb-14">
      <!-- Brand -->
      <div class="col-span-2 nav:col-span-1">
        <img src="/assets/logo-gesper.png" alt="Gesper" class="h-7 mb-4" />
        <p class="text-sm text-[var(--fg-muted)] max-w-[280px] leading-[1.55]">
          Software de recursos humanos de Noanet. Modular, seguro y pensado para crecer con tu empresa.
        </p>
      </div>

      <!-- Producto -->
      <div>
        <h5 class="text-[12px] font-bold tracking-[0.08em] uppercase text-[var(--fg-dim)] mb-4">Producto</h5>
        <ul class="flex flex-col gap-[10px] list-none p-0">
          {product.map((item) => (
            <li><a href={item.href} class="text-sm text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors duration-150">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <h5 class="text-[12px] font-bold tracking-[0.08em] uppercase text-[var(--fg-dim)] mb-4">Empresa</h5>
        <ul class="flex flex-col gap-[10px] list-none p-0">
          {company.map((item) => (
            <li><a href={item.href} class="text-sm text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors duration-150">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Recursos -->
      <div>
        <h5 class="text-[12px] font-bold tracking-[0.08em] uppercase text-[var(--fg-dim)] mb-4">Recursos</h5>
        <ul class="flex flex-col gap-[10px] list-none p-0">
          {resources.map((item) => (
            <li><a href={item.href} class="text-sm text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors duration-150">{item.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-7 border-t border-[var(--border)] flex justify-between flex-wrap gap-3 text-[13px] text-[var(--fg-dim)]">
      <span>© 2026 Noanet. Todos los derechos reservados.</span>
      <span>Términos · Privacidad · Cookies</span>
    </div>

  </div>
</footer>
