---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import adminPersonal from '@/images/administracion_personal.webp';
import controlAsistencia from '@/images/control_asistencia.webp';
import liquidacionHaberes from '@/images/liquidacion_haberes.webp';
import medicinaLaboral from '@/images/medicina_laboral.webp';
import capacitacion from '@/images/capacitacion.webp';
import autogestion from '@/images/autogestion.webp';
import evaluacionDesempeno from '@/images/evaluacion_desempeño.webp';

type ModuleImage = {
  src: ImageMetadata;
  alt: string;
  label: string;
};

type Module = {
  tag: string;
  label: string;
  title: string;
  desc: string;
  features: string[];
  image: ModuleImage;
};

const modules: Module[] = [
  {
    tag: '01',
    label: 'Base',
    title: 'Administración de Personal',
    desc: 'El expediente completo de cada empleado, siempre actualizado. Nómina, datos personales y certificados en un solo lugar — sin papeles, sin redundancias.',
    features: ['Nómina de empleados', 'Datos personales', 'Certificados', 'Registro de sanciones', 'Entrega de materiales'],
    image: {
      src: adminPersonal,
      alt: 'Pantalla de administración de personal en Gesper',
      label: 'Administración de Personal',
    },
  },
  {
    tag: '02',
    label: 'Base',
    title: 'Control de Asistencia',
    desc: 'Definí turnos, novedades y vacaciones. Los datos pasan automáticamente a Liquidación de Haberes — sin recargas manuales, sin errores de transcripción.',
    features: ['Turnos horarios', 'Registro de novedades', 'Gestión de vacaciones', 'Integración con Liquidación'],
    image: {
      src: controlAsistencia,
      alt: 'Pantalla de control de asistencia en Gesper',
      label: 'Control de Asistencia',
    },
  },
  {
    tag: '03',
    label: '',
    title: 'Liquidación de Haberes',
    desc: 'Liquidá sueldos sin errores y en tiempo. Recibos digitales, libros de ley, acreditaciones bancarias y múltiples convenios — todo auditable.',
    features: ['Recibos de sueldo digitales', 'Acreditaciones bancarias', 'Multiconvenio salarial', 'Libro de sueldo digital'],
    image: {
      src: liquidacionHaberes,
      alt: 'Pantalla de liquidación de haberes en Gesper',
      label: 'Liquidación de Haberes',
    },
  },
  {
    tag: '04',
    label: '',
    title: 'Medicina Laboral',
    desc: 'Cumplí con las obligaciones médicas sin burocracia. Historial del empleado y su grupo familiar, con documentación centralizada y acceso inmediato.',
    features: ['Historial médico', 'Grupo familiar', 'Documentación centralizada', 'Seguimiento de aptitudes'],
    image: {
      src: medicinaLaboral,
      alt: 'Pantalla de medicina laboral en Gesper',
      label: 'Medicina Laboral',
    },
  },
  {
    tag: '05',
    label: '',
    title: 'Capacitación',
    desc: 'Sabé quién capacitó qué y cuándo. Programá, ejecutá y auditá capacitaciones por área o perfil — sin hojas de cálculo.',
    features: ['Programación de cursos', 'Seguimiento por empleado', 'Capacitación por perfil', 'Auditoría completa'],
    image: {
      src: capacitacion,
      alt: 'Pantalla de capacitación en Gesper',
      label: 'Capacitación',
    },
  },
  {
    tag: '06',
    label: 'Autogestión',
    title: 'Portal de Autogestión',
    desc: 'El colaborador solicita licencias, descarga sus recibos de sueldo y consulta sus datos sin intermediarios. Menos carga operativa para RRHH, más autonomía para cada empleado.',
    features: ['Solicitud de licencias', 'Descarga de recibos', 'Consulta de datos personales', 'Sin intermediarios'],
    image: {
      src: autogestion,
      alt: 'Pantalla del portal de autogestión en Gesper',
      label: 'Portal de Autogestión',
    },
  },
  {
    tag: '07',
    label: '',
    title: 'Evaluación de desempeño',
    desc: 'Definí objetivos, registrá evaluaciones y acompañá la evolución de cada colaborador con información ordenada para RRHH y líderes de área.',
    features: ['Evaluaciones periódicas', 'Seguimiento por área', 'Historial de desempeño'],
    image: {
      src: evaluacionDesempeno,
      alt: 'Pantalla de evaluación de desempeño en Gesper',
      label: 'Evaluación de desempeño',
    },
  },
];
---

<section class="section" id="modulos">
  <div class="container">

    <div class="section-head">
      <span class="section-eyebrow">Módulos</span>
      <h2 class="h2">Empezá con lo que necesitás. <span class="accent">Escalá cuando quieras.</span></h2>
      <p class="section-sub max-w-lg mx-auto">Siete módulos integrados que comparten datos y se activan según lo que tu empresa requiera. Sin duplicar información, sin sistemas paralelos.</p>
    </div>

    <div class="divide-y divide-[var(--border)]">
      {modules.map((m, i) => {
        const imageDialogId = `module-image-${i}`;
        const imageTitleId = `module-image-title-${i}`;

        return (
        <div class="module-row py-14 nav:py-20">

          <div class="module-heading">
            <div class="module-kicker">
              <span>{m.tag}</span>
              {m.label && (
                <span class="module-label">{m.label}</span>
              )}
            </div>
            <h3 class="module-title">
              {m.title}
            </h3>
          </div>

          <div class="module-body">
            <p class="module-desc">{m.desc}</p>

            <dl class="module-features">
              {m.features.map((f, fi) => (
                <div class="module-feature">
                  <dt>
                    {m.tag}.{String(fi + 1).padStart(1, '0')}
                  </dt>
                  <dd>{f}</dd>
                </div>
              ))}
            </dl>
          </div>

          <div class="module-media">
            <button
              type="button"
              data-lightbox-open={imageDialogId}
              aria-label={`Ampliar imagen de ${m.image.label} para ${m.title}`}
              class="module-shot overflow-hidden rounded-lg border border-[var(--border)] bg-[var(--bg-elev)]"
            >
              <Image
                src={m.image.src}
                alt={m.image.alt}
                width={520}
                widths={[320, 420, 520, 720, 960]}
                loading="lazy"
                sizes="(min-width: 1240px) 425px, (min-width: 900px) 34vw, calc(100vw - 56px)"
                class="h-full w-full object-contain"
              />
              <span class="module-shot-zoom" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="7"></circle>
                  <path d="m16.5 16.5 4 4"></path>
                  <path d="M11 8v6"></path>
                  <path d="M8 11h6"></path>
                </svg>
              </span>
            </button>
          </div>

          <dialog
            id={imageDialogId}
            class="module-lightbox"
            data-module-dialog
            aria-labelledby={imageTitleId}
          >
            <div class="module-lightbox-panel">
              <div class="module-lightbox-bar">
                <h3 id={imageTitleId} class="module-lightbox-title">{m.title} · {m.image.label}</h3>
                <button
                  type="button"
                  class="module-lightbox-close"
                  data-lightbox-close
                  aria-label="Cerrar imagen ampliada"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round">
                    <path d="M18 6 6 18"></path>
                    <path d="m6 6 12 12"></path>
                  </svg>
                </button>
              </div>
              <div class="module-lightbox-image is-loading" data-lightbox-image>
                <div class="module-lightbox-loader" role="status" aria-live="polite">
                  <span class="module-lightbox-spinner" aria-hidden="true"></span>
                  <span class="sr-only">Cargando imagen</span>
                </div>
                <Image
                  src={m.image.src}
                  alt={m.image.alt}
                  width={1180}
                  widths={[640, 960, 1180, 1408, 1716]}
                  loading="lazy"
                  sizes="min(92vw, 1180px)"
                  class="h-full w-full object-contain"
                />
              </div>
            </div>
          </dialog>

        </div>
      )})}
    </div>

  </div>
</section>

<style>
  .module-row {
    display: grid;
    gap: 2rem;
    align-items: start;
  }

  .module-heading,
  .module-body {
    display: grid;
    min-width: 0;
  }

  .module-heading {
    gap: 1.35rem;
  }

  .module-body {
    gap: 1.35rem;
  }

  .module-kicker {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--accent);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .module-label {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 3px 7px;
    color: var(--accent);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .module-title {
    max-width: 440px;
    color: var(--fg);
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .module-desc {
    max-width: 520px;
    margin: 0;
    color: var(--fg-muted);
    font-size: 17px;
    line-height: 1.6;
  }

  .module-features {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    max-width: 520px;
  }

  .module-feature {
    display: flex;
    min-width: 0;
    align-items: baseline;
    gap: 4px;
    border-radius: 8px;
    padding: 10px 12px;
    color: var(--fg-muted);
    background: var(--card);
    font-size: 14px;
    line-height: 1.25;
  }

  .module-feature dt,
  .module-feature dd {
    min-width: 0;
  }

  .module-feature dt {
    flex: 0 0 auto;
    color: var(--fg-muted);
    font-weight: 600;
  }

  .module-feature dd {
    white-space: normal;
  }

  .module-media {
    min-width: 0;
    width: min(100%, 430px);
  }

  .module-shot {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    padding: 0;
    cursor: zoom-in;
    background: #f6f7f4;
    box-shadow:
      0 24px 80px -48px rgba(0, 0, 0, 0.55),
      0 1px 0 rgba(255, 255, 255, 0.04) inset;
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .module-shot::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(to right, var(--bg) 0%, transparent 8%, transparent 92%, var(--bg) 100%),
      linear-gradient(to bottom, transparent 72%, var(--bg) 100%);
    opacity: 0.18;
  }

  .module-shot:hover,
  .module-shot:focus-visible {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  .module-shot:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .module-shot-zoom {
    position: absolute;
    top: 9px;
    right: 9px;
    z-index: 1;
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    color: #fff;
    background: rgba(7, 7, 10, 0.72);
    box-shadow: 0 12px 32px -18px rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
  }

  .module-lightbox {
    width: min(1180px, calc(100vw - 32px));
    max-width: none;
    max-height: calc(100vh - 32px);
    padding: 0;
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    color: var(--fg);
    background: var(--bg-elev);
    box-shadow: 0 40px 120px -52px rgba(0, 0, 0, 0.78);
  }

  .module-lightbox::backdrop {
    background: rgba(7, 7, 10, 0.72);
    backdrop-filter: blur(8px);
  }

  .module-lightbox-panel {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    max-height: calc(100vh - 32px);
  }

  .module-lightbox-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }

  .module-lightbox-title {
    color: var(--fg);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.25;
  }

  .module-lightbox-close {
    display: grid;
    width: 38px;
    height: 38px;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg);
    background: transparent;
    transition:
      border-color 180ms ease,
      background 180ms ease;
  }

  .module-lightbox-close:hover,
  .module-lightbox-close:focus-visible {
    border-color: var(--border-strong);
    background: var(--card);
  }

  .module-lightbox-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .module-lightbox-image {
    position: relative;
    display: grid;
    min-height: 0;
    padding: 16px;
    place-items: center;
    background: #f6f7f4;
    overflow: hidden;
  }

  .module-lightbox-image :global(img) {
    max-height: calc(100vh - 120px);
    opacity: 0;
    transition: opacity 220ms ease;
  }

  .module-lightbox-image.is-loaded :global(img) {
    opacity: 1;
  }

  .module-lightbox-loader {
    position: absolute;
    inset: 16px;
    z-index: 1;
    display: grid;
    gap: 12px;
    place-content: center;
    place-items: center;
    color: var(--fg-muted);
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.58), rgba(255, 255, 255, 0)),
      #f6f7f4;
    background-size: 180% 100%, auto;
    opacity: 1;
    pointer-events: none;
    transition:
      opacity 180ms ease,
      visibility 180ms ease;
    animation: module-loader-sheen 1.2s ease-in-out infinite;
  }

  .module-lightbox-image.is-loaded .module-lightbox-loader {
    visibility: hidden;
    opacity: 0;
  }

  .module-lightbox-spinner {
    width: 34px;
    height: 34px;
    border: 3px solid rgba(30, 30, 36, 0.16);
    border-top-color: var(--accent);
    border-radius: 999px;
    animation: module-loader-spin 780ms linear infinite;
  }

  @keyframes module-loader-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes module-loader-sheen {
    0% {
      background-position: 160% 0, 0 0;
    }

    100% {
      background-position: -60% 0, 0 0;
    }
  }

  [data-theme="light"] .module-shot {
    box-shadow:
      0 28px 90px -58px rgba(20, 9, 26, 0.42),
      0 1px 0 rgba(255, 255, 255, 0.8) inset;
  }

  [data-theme="light"] .module-shot::after {
    opacity: 0.28;
  }

  @media (min-width: 900px) {
    .module-row {
      grid-template-columns: minmax(320px, 0.92fr) minmax(340px, 0.88fr);
      column-gap: clamp(2.5rem, 7vw, 6rem);
    }

    .module-heading {
      grid-column: 1;
    }

    .module-body {
      grid-column: 1;
    }

    .module-media {
      grid-column: 2;
      grid-row: 1 / span 2;
      justify-self: end;
      width: min(100%, 425px);
    }
  }

  @media (max-width: 560px) {
    .module-features {
      grid-template-columns: 1fr;
    }

    .module-feature dd {
      white-space: normal;
    }
  }
</style>

<script>
  const openButtons = document.querySelectorAll<HTMLButtonElement>('[data-lightbox-open]');
  const dialogs = document.querySelectorAll<HTMLDialogElement>('[data-module-dialog]');

  function updateLightboxImageState(dialog: HTMLDialogElement) {
    const imageWrap = dialog.querySelector<HTMLElement>('[data-lightbox-image]');
    const image = imageWrap?.querySelector<HTMLImageElement>('img');

    if (!imageWrap || !image) return;

    const markLoaded = () => {
      imageWrap.classList.remove('is-loading');
      imageWrap.classList.add('is-loaded');
    };

    if (image.complete && image.naturalWidth > 0) {
      markLoaded();
      return;
    }

    imageWrap.classList.remove('is-loaded');
    imageWrap.classList.add('is-loading');
    image.addEventListener('load', markLoaded, { once: true });
  }

  openButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const dialogId = button.dataset.lightboxOpen;
      const dialog = dialogId ? document.getElementById(dialogId) : null;

      if (dialog instanceof HTMLDialogElement) {
        updateLightboxImageState(dialog);
        dialog.showModal();
      }
    });
  });

  dialogs.forEach((dialog) => {
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });

    dialog.querySelectorAll<HTMLButtonElement>('[data-lightbox-close]').forEach((button) => {
      button.addEventListener('click', () => dialog.close());
    });
  });
</script>
